<!DOCTYPE html>
<html lang="en">
{% include "head.njk" %}

<body>

    {% set the_slides = slides.items %}

    {% set one_p = the_slides | pluck("level", 1) %}
    {% set two_p = the_slides | pluck("level", 2) %}
    {% set three_p = the_slides | pluck("level", 3) %}

    {% set one_pointers = one_p | randomize %}
    {% set two_pointers = two_p | randomize %}
    {% set three_pointers = three_p | randomize %}

    {% set the_twelve_one_pointers = one_pointers | slice(0, 15) %}
    {% set the_eight_one_pointers = one_pointers | slice(15, 24) %}
    {% set the_four_one_pointers = one_pointers | slice(24, 27) %}

    {% set the_remaining_one_pointers = one_pointers | slice(27, 37) %}

    {% set the_twelve_two_pointers = two_pointers | slice(0, 10) %}
    {% set the_eight_two_pointers = two_pointers | slice(10, 17) %}
    {% set the_four_two_pointers = two_pointers | slice(20, 27) %}

    {% set the_remaining_two_pointers = two_pointers | slice(27, 37) %}

    {% set the_twelve_three_pointers = three_pointers | slice(0, 5) %}
    {% set the_eight_three_pointers = three_pointers | slice(5, 15) %}
    {% set the_four_three_pointers = three_pointers | slice(15, 26) %}

    {% set the_remaining_three_pointers = three_pointers | slice(26, 36) %}

    {% set the_twelve_temp = the_twelve_one_pointers | concat(the_twelve_two_pointers) %}
    {% set the_twelve_final = the_twelve_temp | concat(the_twelve_three_pointers) %}
    {% set the_twelve = the_twelve_final | randomize %}

    {% set the_eight_temp = the_eight_one_pointers | concat(the_eight_two_pointers) %}
    {% set the_eight_final = the_eight_temp | concat(the_eight_three_pointers) %}
    {% set the_eight = the_eight_final | randomize %}

    {% set the_four_temp = the_four_one_pointers | concat(the_four_two_pointers) %}
    {% set the_four_final = the_four_temp | concat(the_four_three_pointers) %}
    {% set the_four = the_four_final | randomize %}

    {% set the_remaining_temp = the_remaining_one_pointers | concat(the_remaining_two_pointers) %}
    {% set the_remaining_final = the_remaining_temp | concat(the_remaining_three_pointers) %}
    {% set the_remaining = the_remaining_final | randomize %}

    {% if id == 'twelve' %}
        {% set the_slides = the_twelve %}
    {% endif %}
    {% if id == 'eight' %}
        {% set the_slides = the_eight %}
    {% endif %}
    {% if id == 'four' %}
        {% set the_slides = the_four %}
    {% endif %}
    {% if id == 'extra' %}
        {% set the_slides = the_remaining %}
    {% endif %}
    {% include "slides.njk" %}

    <a href="{{ '/' | url }}" class="home">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" stroke="#607d8b" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12H3l9-9 9 9h-2M5 12v7a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-7"/><path d="M10 12h4v4h-4z"/></svg>
    </a>

    {{ content | safe }}
    
    <script src="{{ '/assets/js/reveal.js' | url }}"></script>

    <script>
        // More info about initialization & config:
        // - https://revealjs.com/initialization/
        // - https://revealjs.com/config/
        Reveal.initialize({
            hash: true,
            slideNumber: true,

            // Learn about plugins: https://revealjs.com/plugins/
            // plugins: [RevealMarkdown, RevealHighlight, RevealNotes],
        });
    </script>

<script>
  const START_TIME = 2 * 60; // 2 minutes

  const timers = document.querySelectorAll(".timer");

  const timerStates = new Map();

  timers.forEach((timer) => {
    timerStates.set(timer, {
      timeLeft: START_TIME,
      intervalId: null
    });
  });

  function formatTime(seconds) {
    const minutes = Math.floor(seconds / 60);
    const remainingSeconds = seconds % 60;

    return `${String(minutes).padStart(2, "0")}:${String(remainingSeconds).padStart(2, "0")}`;
  }

  function renderTimer(timer) {
    const state = timerStates.get(timer);
    timer.textContent = formatTime(state.timeLeft);
  }

  function startTimer(timer) {
    const state = timerStates.get(timer);

    if (state.intervalId !== null) return;

    state.intervalId = setInterval(() => {
      renderTimer(timer);

      if (state.timeLeft <= 0) {
        clearInterval(state.intervalId);
        state.intervalId = null;
        return;
      }

      state.timeLeft--;
    }, 1000);
  }

  function resetTimer(timer) {
    const state = timerStates.get(timer);

    clearInterval(state.intervalId);
    state.intervalId = null;
    state.timeLeft = START_TIME;

    renderTimer(timer);
  }

  timers.forEach(renderTimer);

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        const timer = entry.target;

        if (entry.isIntersecting) {
          startTimer(timer);
        } else {
          resetTimer(timer);
        }
      });
    },
    {
      threshold: 0.5
    }
  );

  timers.forEach((timer) => observer.observe(timer));
</script>

<script>
    document.querySelectorAll('.a').forEach((card) => {
        card.addEventListener('click', () => {
            card.classList.toggle('is-flipped');
        });
    });
</script>
    
</body>
</html>