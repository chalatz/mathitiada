---
layout: default.njk
---
{% set randomSlides = slides.items | randomLevelItems(1, 15) %}

<div class="reveal">
    <div class="slides">
        {% for item in randomSlides %}
            <section class="card">
                <h2 class="q">
                    {{ item.q }}
                </h2>
                {% if item.image %}
                    <img src="{{ item.image | url }}" alt="Image" class="slide-image">
                {% endif %}
                {% if item.audio %}
                    <audio controls src="{{ item.audio | url }}"></audio>
                {% endif %}

                <div class="a">
                    <div class="a__container">
                        <div class="a__front">
                            Απάντηση
                        </div>
                        <div class="a__back">
                            {{ item.a }}
                        </div>
                    </div>
                </div>
            </section>
            
        {% endfor %}

    </div>
</div>