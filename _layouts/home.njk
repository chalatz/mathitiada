        .container h2 {
            font-size: 2.5em;
            font-weight: 600;
            text-align: center;
            margin-top: 10px;
        }
        .links {
            margin-top: 20px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            width: 100%;
        }
        .links a {
            color: #fdf6e3;
            display: block;
            text-decoration: none;
            margin: 20px 0;
            font-size: 2em;
            border: 2px solid #fdf6e3;
            padding: 10px 20px;
            border-radius: 5px;
            transition: background-color 0.3s, color 0.3s;
            width: 100%;
            text-align: center;
        }

        .links a:hover {
            background-color: #fdf6e3;
            color: #2b2b2b;
        }
    </style>
</head>
